# DIPS 2.0 API 認証情報（国交省から発行される）
DIPS_CLIENT_ID=your_client_id_here
DIPS_CLIENT_SECRET=your_client_secret_here

# 環境設定: staging / production
DIPS_ENV=staging

# FastAPI
APP_HOST=0.0.0.0
APP_PORT=8000
APP_SECRET_KEY=change-this-to-a-random-secret-key

# 許可するオリジン（Flutter Web のURL）
CORS_ORIGINS=https://moriokadronesquad.github.io,http://localhost:8080

# トークン暗号化キー（Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"）
TOKEN_ENCRYPTION_KEY=generate-with-fernet

# ログレベル
LOG_LEVEL=INFO
